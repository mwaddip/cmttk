              "description": "Cost per collection interval in payment token base units",
              "$ref": "#/definitions/Int"
            },
            {
              "title": "interval_ms",
              "description": "Collection interval in milliseconds (e.g. 86_400_000 = 1 day)",
              "$ref": "#/definitions/Int"
            },
            {
              "title": "last_collected",
              "description": "POSIX ms of the last partial collection (or subscription creation)",
